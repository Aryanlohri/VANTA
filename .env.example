# ============================================
# AI Code Review Platform — Environment Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- GitHub OAuth ----
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ---- OpenAI ----
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
# Set to "true" to use mock AI responses (no API calls)
AI_MOCK_MODE=true

# ---- JWT ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=7d

# ---- PostgreSQL ----
POSTGRES_USER=aicr_user
POSTGRES_PASSWORD=aicr_password_change_me
POSTGRES_DB=aicr_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aicr_user:aicr_password_change_me@localhost:5432/aicr_db

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Service Ports ----
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
REPO_SERVICE_PORT=3002
REVIEW_SERVICE_PORT=3003
AI_SERVICE_PORT=3004

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=http://localhost:3003

# ---- Encryption ----
# For encrypting GitHub access tokens at rest
ENCRYPTION_KEY=change_me_to_a_32_char_hex_string
